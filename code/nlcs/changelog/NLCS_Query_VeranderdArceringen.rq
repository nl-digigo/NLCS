PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?NLCSArcering ?id_nummer ?oudeNLCSArceringName ?nieuweNLCSArceringName
FROM NAMED <http://hub.laces.tech/digitalbuildingdata/nlcs/live/nlcs/versions/5_0_2> 

WHERE {

    FILTER (STRSTARTS(STR(?NLCSArcering), "http://digitalbuildingdata.tech/nlcs/def/"))
    ?NLCSArcering rdfs:subClassOf+/skos:prefLabel "Arcering" ;
                 skos:prefLabel ?nieuweNLCSArceringName .
    OPTIONAL {
        ?NLCSArcering <http://digitalbuildingdata.tech/nlcs/def/b718adec73e04ce3ec720dd11a06a308> ?id_nummer .
    }

    GRAPH <http://hub.laces.tech/digitalbuildingdata/nlcs/live/nlcs/versions/5_0_2> {
        FILTER (STRSTARTS(STR(?NLCSArcering), "http://digitalbuildingdata.tech/nlcs/def/"))
        ?NLCSArcering skos:prefLabel ?oudeNLCSArceringName .
    }

    FILTER (?nieuweNLCSArceringName != ?oudeNLCSArceringName)
}